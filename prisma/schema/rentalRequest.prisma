model RentalRequest {
    id          String              @id @default(uuid())
    tenant_id   String
    user        User                @relation(fields: [tenant_id], references: [id], onDelete: Restrict)
    property_id String
    property    Property            @relation(fields: [property_id], references: [id], onDelete: Restrict)
    message     String
    status      RentalRequestStatus @default(PENDING)
    start_date  DateTime
    end_date    DateTime
    created_at  DateTime            @default(now())
    updated_at  DateTime            @updatedAt
    review      Review?
    payment     Payment?

    @@map("rental_requests")
}
